{
  "App": {
    "ClientUrl": "http://localhost:4200"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.ApplicationInsights" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{RequestId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/podium-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{RequestId}] [{UserId}] {Message:lj}{Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "ApplicationInsights",
        "Args": {
          "connectionString": "",
          "restrictedToMinimumLevel": "Information",
          "telemetryConverter": "Serilog.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithProcessId", "WithEnvironmentName" ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=PodiumDb;Trusted_Connection=true;MultipleActiveResultSets=true"
  },
  "JWT": {
    "Secret": "",
    "Issuer": "PodiumAPI",
    "Audience": "PodiumClient",
    "ExpirationMinutes": 60
  },
  "Video": {
    "TranscodingSecret": "",
    "MaxFileSizeMB": 500
  },
  "StorageProvider": "Azure",
  "AzureStorage": {
    "ConnectionString": "",
    "ContainerName": "podium-videos"
  },
  "AWS": {
    "Region": "us-east-1",
    "BucketName": "podium-videos-bucket",
    "AccessKey": "",
    "SecretKey": ""
  },
  "SendGrid": {
    "ApiKey": "",
    "FromEmail": "noreply@podiumapp.com",
    "FromName": "Podium Application"
  },
  "AllowedOrigins": [
    "http://localhost:4200",
    "https://localhost:4200"
  ],
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 60
      }
    ],
    "EndpointWhitelist": [
      "get:/health",
      "get:/ready"
    ],
    "ClientWhitelist": [],
    "IpWhitelist": []
  },
  "IpRateLimitPolicies": {
    "IpRules": [
      {
        "Ip": "*",
        "Rules": [
          {
            "Endpoint": "*/api/auth/login",
            "Period": "1m",
            "Limit": 10
          },
          {
            "Endpoint": "*/api/auth/register",
            "Period": "1m",
            "Limit": 10
          }
        ]
      }
    ]
  },
  "RateLimit": {
    "EnableRateLimiting": true,
    "PermitLimit": 10,
    "WindowSeconds": 60
  },
  "SecurityHeaders": {
    "EnableHSTS": false,
    "HSTSMaxAge": 31536000,
    "EnableCSP": true
  }
}