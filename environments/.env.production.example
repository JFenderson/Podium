# ============================================================================
# Podium Production Environment Configuration
# ============================================================================
# This file documents all environment variables for PRODUCTION ENVIRONMENT
# ALL VALUES MUST BE STORED IN AZURE KEY VAULT
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------

# SQL Server Connection String (Production)
# Required: YES
# Description: Azure SQL Database connection with high availability
# Example: Server=tcp:podium-sql-production.database.windows.net,1433;...
# Where to obtain: Azure Portal > SQL Database > Connection Strings
# Storage: Azure Key Vault secret 'sql-connection-string'
# Rotation: Every 90 days
ConnectionStrings__DefaultConnection=@Microsoft.KeyVault(SecretUri=https://podium-kv-production.vault.azure.net/secrets/sql-connection-string/)

# ----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# ----------------------------------------------------------------------------

# JWT Secret Key
# Required: YES
# Description: Production secret key for JWT tokens (minimum 48 characters)
# Example: [STORED IN KEY VAULT - NEVER EXPOSE]
# Where to obtain: Generate using: openssl rand -base64 64
# Storage: Azure Key Vault secret 'jwt-secret'
# Rotation: Every 180 days
JWT__Secret=@Microsoft.KeyVault(SecretUri=https://podium-kv-production.vault.azure.net/secrets/jwt-secret/)
JWT__Issuer=PodiumAPI
JWT__Audience=PodiumClient
JWT__ExpirationMinutes=60

# Video Transcoding Secret
# Required: YES
# Description: Production secret for video processing
# Example: [STORED IN KEY VAULT - NEVER EXPOSE]
# Where to obtain: Generate using: openssl rand -base64 48
# Storage: Azure Key Vault secret 'video-transcoding-secret'
# Rotation: Every 180 days
Video__TranscodingSecret=@Microsoft.KeyVault(SecretUri=https://podium-kv-production.vault.azure.net/secrets/video-transcoding-secret/)

# ----------------------------------------------------------------------------
# STORAGE CONFIGURATION
# ----------------------------------------------------------------------------

# Storage Provider
# Required: YES
# Description: Azure Blob Storage for production workloads
StorageProvider=Azure

# Azure Storage Connection String
# Required: YES
# Description: Geo-redundant storage connection string
# Example: [STORED IN KEY VAULT - NEVER EXPOSE]
# Where to obtain: Azure Portal > Storage Account (GRS) > Access Keys
# Storage: Azure Key Vault secret 'storage-connection-string'
# Rotation: Every 90 days
AzureStorage__ConnectionString=@Microsoft.KeyVault(SecretUri=https://podium-kv-production.vault.azure.net/secrets/storage-connection-string/)
AzureStorage__ContainerName=podium-videos

# ----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# ----------------------------------------------------------------------------

# SendGrid API Key
# Required: YES
# Description: Production SendGrid API key with appropriate sending limits
# Example: [STORED IN KEY VAULT - NEVER EXPOSE]
# Where to obtain: SendGrid Dashboard > Settings > API Keys (Production key)
# Storage: Azure Key Vault secret 'sendgrid-api-key'
# Rotation: Every 180 days
SendGrid__ApiKey=@Microsoft.KeyVault(SecretUri=https://podium-kv-production.vault.azure.net/secrets/sendgrid-api-key/)
SendGrid__FromEmail=noreply@podiumapp.com
SendGrid__FromName=Podium

# ----------------------------------------------------------------------------
# CORS & URLS
# ----------------------------------------------------------------------------

# Allowed Origins for CORS
# Required: YES
# Description: Production frontend URLs (custom domain)
# Example: https://www.podiumapp.com, https://app.podiumapp.com
# Where to obtain: Your production domain
AllowedOrigins__0=https://www.podiumapp.com
AllowedOrigins__1=https://app.podiumapp.com
AllowedOrigins__2=https://podium-cdn.azureedge.net

# Application Client URL
# Required: YES
# Description: Primary production frontend URL
# Example: https://www.podiumapp.com
App__ClientUrl=https://www.podiumapp.com

# ----------------------------------------------------------------------------
# MONITORING & LOGGING
# ----------------------------------------------------------------------------

# Application Insights Connection String
# Required: YES
# Description: Production Application Insights for monitoring and alerting
# Example: InstrumentationKey=...;IngestionEndpoint=https://...
# Where to obtain: Azure Portal > Application Insights > Properties
# Note: Can be in Key Vault or direct (not sensitive)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://eastus-1.in.applicationinsights.azure.com/

# Enable Application Insights
# Required: YES
# Description: MUST be enabled in production
ENABLE_APPLICATION_INSIGHTS=true

# Logging Level
# Required: YES
# Description: Production logging level (Warning or Error for performance)
# Example: Warning
LOG_LEVEL=Warning
Logging__LogLevel__Default=Warning
Logging__LogLevel__Microsoft=Error
Logging__LogLevel__MicrosoftAspNetCore=Error

# Serilog Configuration
Serilog__MinimumLevel__Default=Warning
Serilog__MinimumLevel__Override__Microsoft=Error
Serilog__MinimumLevel__Override__System=Error

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------

# Rate Limiting Configuration
# Required: YES
# Description: Strict rate limiting for production
RateLimit__EnableRateLimiting=true
RateLimit__PermitLimit=60
RateLimit__WindowSeconds=60

# ----------------------------------------------------------------------------
# SECURITY HEADERS
# ----------------------------------------------------------------------------

# Security Headers Configuration
# Required: YES
# Description: Full security headers enabled
SecurityHeaders__EnableHSTS=true
SecurityHeaders__HSTSMaxAge=31536000
SecurityHeaders__EnableCSP=true

# ----------------------------------------------------------------------------
# APPLICATION ENVIRONMENT
# ----------------------------------------------------------------------------

# ASP.NET Core Environment
# Required: YES
# Description: MUST be set to Production
ASPNETCORE_ENVIRONMENT=Production

# ASP.NET Core URLs
# Required: YES
# Description: Listen on HTTP (behind load balancer/App Gateway with SSL termination)
ASPNETCORE_URLS=http://+:5000

# ----------------------------------------------------------------------------
# VIDEO PROCESSING
# ----------------------------------------------------------------------------

# Maximum Video File Size
# Required: YES
# Description: Production limit for video uploads
Video__MaxFileSizeMB=500

# ----------------------------------------------------------------------------
# HEALTH CHECKS
# ----------------------------------------------------------------------------

# Health Check Interval
# Required: YES
# Description: Frequent health checks for production monitoring
HEALTH_CHECK_INTERVAL_SECONDS=30

# ============================================================================
# PRODUCTION SECURITY REQUIREMENTS
# ============================================================================
# 
# CRITICAL - ALL OF THE FOLLOWING MUST BE TRUE:
# 
# 1. All secrets stored in Azure Key Vault (ZERO secrets in code or configs)
# 2. Managed Identity enabled on App Service
# 3. Key Vault access policies configured for App Service identity
# 4. HTTPS enforced (HTTP redirects to HTTPS)
# 5. TLS 1.2 minimum enforced
# 6. SQL Server firewall allows only Azure services
# 7. Storage account disables public blob access
# 8. Application Insights enabled for monitoring
# 9. Diagnostic settings enabled (logs to Log Analytics)
# 10. DDoS protection enabled on virtual network (if applicable)
# 11. Azure Security Center recommendations addressed
# 12. All security alerts configured and tested
# 13. Backup and disaster recovery tested
# 14. Secrets rotation schedule documented and followed
# 15. Access control (RBAC) properly configured
# 
# ============================================================================

# ============================================================================
# DEPLOYMENT CHECKLIST
# ============================================================================
#
# Before deploying to production:
#
# □ All secrets rotated to production values
# □ Connection strings validated
# □ SSL certificates installed and tested
# □ Custom domains configured
# □ DNS records updated
# □ CDN configured with custom domain
# □ Application Insights alerts tested
# □ Health check endpoints responding
# □ Database migrations tested on staging
# □ Backup verified within last 24 hours
# □ Rollback procedure documented and tested
# □ Monitoring dashboard created
# □ On-call rotation established
# □ Incident response plan reviewed
# □ Performance baselines established
# □ Load testing completed
# □ Security scan passed
# □ Penetration testing completed
# □ All team members trained on deployment
# □ Stakeholders notified of deployment window
#
# ============================================================================

# ============================================================================
# SECRET ROTATION SCHEDULE
# ============================================================================
#
# The following secrets must be rotated on schedule:
#
# Every 90 days:
# - Database passwords (sql-connection-string)
# - Storage account keys (storage-connection-string)
#
# Every 180 days:
# - JWT secret (jwt-secret)
# - Video transcoding secret (video-transcoding-secret)
# - SendGrid API key (sendgrid-api-key)
#
# Every 365 days:
# - Service principal secrets (if used)
# - Azure AD application secrets (if used)
#
# Automatic:
# - SSL/TLS certificates (auto-renewed 30 days before expiry)
#
# Rotation procedure:
# 1. Generate new secret
# 2. Add new secret to Key Vault with version
# 3. Deploy application with reference to new version
# 4. Verify application functionality
# 5. Remove old secret version after 7 days
# 6. Document rotation in audit log
#
# ============================================================================

# ============================================================================
# MANAGED IDENTITY CONFIGURATION
# ============================================================================
#
# Production MUST use managed identities for service-to-service auth:
#
# App Service Managed Identity:
# - System-assigned identity enabled
# - Used for: Key Vault access, SQL Database (optional), Storage (optional)
#
# Key Vault Access Policy:
# - Principal: App Service system-assigned identity
# - Secret permissions: Get, List
# - No key or certificate permissions needed
#
# SQL Database (optional AAD auth):
# - Can use managed identity instead of SQL auth
# - Requires: ALTER ROLE db_datareader ADD MEMBER [app-service-name]
#
# Storage Account (optional AAD auth):
# - Can use managed identity instead of connection string
# - Requires: Storage Blob Data Contributor role assignment
#
# ============================================================================

# ============================================================================
# PERFORMANCE & SCALING
# ============================================================================
#
# Production Performance Settings:
# - App Service Plan: P1v2 (can scale to P2v2/P3v2 for growth)
# - Auto-scale: CPU > 70% scale out, CPU < 40% scale in
# - Min instances: 1, Max instances: 8
# - SQL Database: S2 (can scale to S3 or Premium for growth)
# - Storage: GRS (geo-redundant)
# - CDN: Standard Microsoft tier
#
# Expected Performance:
# - Response time: < 200ms (P95)
# - Throughput: 1000 req/min
# - Availability: 99.9% uptime
#
# ============================================================================
