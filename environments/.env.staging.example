# ============================================================================
# Podium Staging Environment Configuration
# ============================================================================
# This file documents all environment variables for STAGING ENVIRONMENT
# Values should be stored in Azure Key Vault and referenced in App Service
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------

# SQL Server Connection String (Staging)
# Required: YES
# Description: Azure SQL Database connection string
# Example: Server=tcp:podium-sql-staging.database.windows.net,1433;Initial Catalog=PodiumDb;...
# Where to obtain: Azure Portal > SQL Database > Connection Strings
# Storage: Azure Key Vault secret 'sql-connection-string'
ConnectionStrings__DefaultConnection=@Microsoft.KeyVault(SecretUri=https://podium-kv-staging.vault.azure.net/secrets/sql-connection-string/)

# ----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# ----------------------------------------------------------------------------

# JWT Secret Key
# Required: YES
# Description: Secret key for signing JWT tokens (minimum 32 characters)
# Example: [STORED IN KEY VAULT]
# Where to obtain: Generate using: openssl rand -base64 48
# Storage: Azure Key Vault secret 'jwt-secret'
JWT__Secret=@Microsoft.KeyVault(SecretUri=https://podium-kv-staging.vault.azure.net/secrets/jwt-secret/)
JWT__Issuer=PodiumAPI
JWT__Audience=PodiumClient
JWT__ExpirationMinutes=60

# Video Transcoding Secret
# Required: YES
# Description: Secret for video processing operations
# Example: [STORED IN KEY VAULT]
# Where to obtain: Generate using: openssl rand -base64 32
# Storage: Azure Key Vault secret 'video-transcoding-secret'
Video__TranscodingSecret=@Microsoft.KeyVault(SecretUri=https://podium-kv-staging.vault.azure.net/secrets/video-transcoding-secret/)

# ----------------------------------------------------------------------------
# STORAGE CONFIGURATION
# ----------------------------------------------------------------------------

# Storage Provider Selection
# Required: YES
# Description: Cloud storage provider (Azure recommended for Azure deployment)
# Example: Azure
StorageProvider=Azure

# Azure Storage Connection String
# Required: YES
# Description: Azure Blob Storage connection string
# Example: [STORED IN KEY VAULT]
# Where to obtain: Azure Portal > Storage Account > Access Keys
# Storage: Azure Key Vault secret 'storage-connection-string'
AzureStorage__ConnectionString=@Microsoft.KeyVault(SecretUri=https://podium-kv-staging.vault.azure.net/secrets/storage-connection-string/)
AzureStorage__ContainerName=podium-videos-staging

# ----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# ----------------------------------------------------------------------------

# SendGrid API Key
# Required: YES
# Description: API key for sending transactional emails
# Example: [STORED IN KEY VAULT]
# Where to obtain: SendGrid Dashboard > Settings > API Keys
# Storage: Azure Key Vault secret 'sendgrid-api-key'
SendGrid__ApiKey=@Microsoft.KeyVault(SecretUri=https://podium-kv-staging.vault.azure.net/secrets/sendgrid-api-key/)
SendGrid__FromEmail=staging@podiumapp.com
SendGrid__FromName=Podium Staging

# ----------------------------------------------------------------------------
# CORS & URLS
# ----------------------------------------------------------------------------

# Allowed Origins for CORS
# Required: YES
# Description: Frontend URLs allowed to access the API
# Example: https://podium-frontend-staging.azurewebsites.net
# Where to obtain: Azure Portal > App Service > Overview > URL
AllowedOrigins__0=https://podium-frontend-staging.azurewebsites.net
AllowedOrigins__1=https://podium-cdn-endpoint-staging.azureedge.net

# Application Client URL
# Required: YES
# Description: Frontend application URL for callbacks and redirects
# Example: https://podium-frontend-staging.azurewebsites.net
App__ClientUrl=https://podium-frontend-staging.azurewebsites.net

# ----------------------------------------------------------------------------
# MONITORING & LOGGING
# ----------------------------------------------------------------------------

# Application Insights Connection String
# Required: YES
# Description: Azure Application Insights for telemetry and monitoring
# Example: InstrumentationKey=...;IngestionEndpoint=https://...
# Where to obtain: Azure Portal > Application Insights > Properties
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://eastus-1.in.applicationinsights.azure.com/

# Enable Application Insights
# Required: YES
# Description: Always enabled in staging for testing monitoring
# Example: true
ENABLE_APPLICATION_INSIGHTS=true

# Logging Level
# Required: YES
# Description: Minimum log level (more verbose in staging)
# Example: Information
LOG_LEVEL=Information
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft=Warning
Logging__LogLevel__MicrosoftAspNetCore=Warning

# Serilog Configuration
Serilog__MinimumLevel__Default=Information
Serilog__MinimumLevel__Override__Microsoft=Warning
Serilog__MinimumLevel__Override__System=Warning

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------

# Rate Limiting Configuration
# Required: YES
# Description: API rate limiting to prevent abuse
# Example: true
RateLimit__EnableRateLimiting=true
RateLimit__PermitLimit=60
RateLimit__WindowSeconds=60

# ----------------------------------------------------------------------------
# SECURITY HEADERS
# ----------------------------------------------------------------------------

# Security Headers Configuration
# Required: YES
# Description: HTTP security headers for enhanced security
# Example: true
SecurityHeaders__EnableHSTS=true
SecurityHeaders__HSTSMaxAge=31536000
SecurityHeaders__EnableCSP=true

# ----------------------------------------------------------------------------
# APPLICATION ENVIRONMENT
# ----------------------------------------------------------------------------

# ASP.NET Core Environment
# Required: YES
# Description: Application runtime environment
# Example: Staging
ASPNETCORE_ENVIRONMENT=Staging

# ASP.NET Core URLs
# Required: YES
# Description: URLs the application listens on (container/App Service)
# Example: http://+:5000
ASPNETCORE_URLS=http://+:5000

# ----------------------------------------------------------------------------
# VIDEO PROCESSING
# ----------------------------------------------------------------------------

# Maximum Video File Size
# Required: YES
# Description: Maximum allowed video upload size in MB
# Example: 500
Video__MaxFileSizeMB=500

# ----------------------------------------------------------------------------
# HEALTH CHECKS
# ----------------------------------------------------------------------------

# Health Check Interval
# Required: YES
# Description: Interval in seconds for health check evaluations
# Example: 30
HEALTH_CHECK_INTERVAL_SECONDS=30

# ----------------------------------------------------------------------------
# MANAGED IDENTITY
# ----------------------------------------------------------------------------

# Managed Identity is automatically configured by Azure App Service
# No additional configuration needed - App Service will inject identity
# The identity is used to access:
# - Azure Key Vault (for secrets)
# - Azure SQL Database (optional, currently using SQL auth)
# - Azure Storage (optional, currently using connection string)

# ============================================================================
# DEPLOYMENT NOTES
# ============================================================================
# 
# 1. All secrets MUST be stored in Azure Key Vault
# 2. App Service configuration uses Key Vault references (@Microsoft.KeyVault...)
# 3. Managed Identity must have access policies configured in Key Vault
# 4. Connection strings are configured in App Service Connection Strings section
# 5. Application settings are configured in App Service Application Settings
# 
# To configure in Azure App Service:
# 1. Navigate to: Azure Portal > App Service > Configuration
# 2. Add Application Settings with Key Vault references
# 3. Add Connection String for database
# 4. Enable Managed Identity: Identity > System assigned > On
# 5. Grant Key Vault access: Key Vault > Access policies > Add Access Policy
# 
# Key Vault Access Policy Requirements:
# - Secret permissions: Get, List
# - Principal: App Service managed identity
# 
# ============================================================================

# ============================================================================
# STAGING-SPECIFIC FEATURES
# ============================================================================
#
# Staging environment is used for:
# - Integration testing with production-like configuration
# - Performance testing and load testing
# - UAT (User Acceptance Testing)
# - Testing deployment procedures
# - Validating database migrations
#
# Differences from Production:
# - More verbose logging (Information vs Warning)
# - Possibly smaller/cheaper resource SKUs
# - May have test data or synthetic data
# - Relaxed rate limiting for testing
#
# ============================================================================
