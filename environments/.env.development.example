# ============================================================================
# Podium Development Environment Configuration
# ============================================================================
# This file documents all environment variables for LOCAL DEVELOPMENT
# Copy values to your .env file (DO NOT commit .env to source control)
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------

# SQL Server Connection String (Development)
# Required: YES
# Description: Database connection for local development
# Example: Server=localhost;Database=PodiumDb;Trusted_Connection=true;MultipleActiveResultSets=true
# Where to obtain: Local SQL Server or Docker container
ConnectionStrings__DefaultConnection=Server=localhost;Database=PodiumDb;Trusted_Connection=true;MultipleActiveResultSets=true

# SQL Server SA Password (for Docker)
# Required: YES (if using Docker)
# Description: SA password for SQL Server container
# Example: YourVeryStrongPassword123!
# Where to obtain: Generate a strong password (min 8 chars, complexity required)
DB_SA_PASSWORD=YourVeryStrongPassword123!

# ----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# ----------------------------------------------------------------------------

# JWT Secret Key
# Required: YES
# Description: Secret key for signing JWT tokens (minimum 32 characters)
# Example: your-super-secret-key-at-least-32-characters-long-development
# Where to obtain: Generate using: openssl rand -base64 32
JWT__Secret=your-super-secret-key-at-least-32-characters-long-development
JWT__Issuer=PodiumAPI
JWT__Audience=PodiumClient
JWT__ExpirationMinutes=60

# Video Transcoding Secret
# Required: YES
# Description: Secret for video processing operations
# Example: your-video-transcoding-secret-key-development
# Where to obtain: Generate using: openssl rand -base64 24
Video__TranscodingSecret=your-video-transcoding-secret-key-development

# ----------------------------------------------------------------------------
# STORAGE CONFIGURATION
# ----------------------------------------------------------------------------

# Storage Provider Selection
# Required: YES
# Description: Choose between Azure or AWS for file storage
# Example: Azure
# Where to obtain: Choose based on your cloud provider
StorageProvider=Azure

# Azure Storage Settings
# Required: YES (if using Azure)
# Description: Azure Blob Storage connection string for storing videos and files
# Example: DefaultEndpointsProtocol=https;AccountName=devstorageaccount;AccountKey=...
# Where to obtain: Azure Portal > Storage Account > Access Keys
AzureStorage__ConnectionString=UseDevelopmentStorage=true
AzureStorage__ContainerName=podium-videos-dev

# AWS Storage Settings (Alternative to Azure)
# Required: YES (if using AWS)
# Description: AWS S3 credentials for file storage
# Example: AKIAIOSFODNN7EXAMPLE
# Where to obtain: AWS Console > IAM > Users > Security Credentials
AWS__Region=us-east-1
AWS__BucketName=podium-videos-dev
AWS__AccessKey=YOUR_AWS_ACCESS_KEY
AWS__SecretKey=YOUR_AWS_SECRET_KEY

# ----------------------------------------------------------------------------
# EMAIL CONFIGURATION
# ----------------------------------------------------------------------------

# SendGrid API Key
# Required: NO (for development)
# Description: API key for sending emails via SendGrid
# Example: SG.xxxxxxxxxxxxxxxxxxxxxxxx
# Where to obtain: SendGrid Dashboard > Settings > API Keys
SendGrid__ApiKey=YOUR_SENDGRID_API_KEY
SendGrid__FromEmail=dev@podiumapp.local
SendGrid__FromName=Podium Dev

# ----------------------------------------------------------------------------
# CORS & URLS
# ----------------------------------------------------------------------------

# Allowed Origins for CORS
# Required: YES
# Description: Frontend URLs allowed to access the API
# Example: http://localhost:4200
# Where to obtain: Your frontend development URL
AllowedOrigins__0=http://localhost:4200
AllowedOrigins__1=http://localhost:3000

# Application Client URL
# Required: YES
# Description: Frontend application URL for callbacks
# Example: http://localhost:4200
# Where to obtain: Your frontend development server
App__ClientUrl=http://localhost:4200

# ----------------------------------------------------------------------------
# MONITORING & LOGGING
# ----------------------------------------------------------------------------

# Application Insights Connection String
# Required: NO (for development)
# Description: Azure Application Insights for telemetry and monitoring
# Example: InstrumentationKey=00000000-0000-0000-0000-000000000000;...
# Where to obtain: Azure Portal > Application Insights > Properties
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Enable Application Insights
# Required: NO
# Description: Enable or disable Application Insights telemetry
# Example: false
# Where to obtain: Set to false for local development
ENABLE_APPLICATION_INSIGHTS=false

# Logging Level
# Required: NO
# Description: Minimum log level for application logging
# Example: Information
# Where to obtain: Choose from: Trace, Debug, Information, Warning, Error, Critical
LOG_LEVEL=Debug
Logging__LogLevel__Default=Debug
Logging__LogLevel__Microsoft=Information

# Serilog Configuration
# Required: NO
# Description: Structured logging configuration
Serilog__MinimumLevel__Default=Debug
Serilog__MinimumLevel__Override__Microsoft=Information
Serilog__MinimumLevel__Override__System=Information

# ----------------------------------------------------------------------------
# RATE LIMITING
# ----------------------------------------------------------------------------

# Rate Limiting Configuration
# Required: NO
# Description: API rate limiting settings
# Example: true
# Where to obtain: Set to false to disable rate limiting in development
RateLimit__EnableRateLimiting=false
RateLimit__PermitLimit=100
RateLimit__WindowSeconds=60

# ----------------------------------------------------------------------------
# SECURITY HEADERS
# ----------------------------------------------------------------------------

# Security Headers Configuration
# Required: NO
# Description: HTTP security headers configuration
# Example: false
# Where to obtain: Set to false for development (HSTS interferes with http://)
SecurityHeaders__EnableHSTS=false
SecurityHeaders__HSTSMaxAge=0
SecurityHeaders__EnableCSP=true

# ----------------------------------------------------------------------------
# APPLICATION ENVIRONMENT
# ----------------------------------------------------------------------------

# ASP.NET Core Environment
# Required: YES
# Description: Application runtime environment
# Example: Development
# Where to obtain: Set to Development for local work
ASPNETCORE_ENVIRONMENT=Development

# ASP.NET Core URLs
# Required: NO
# Description: URLs the application listens on
# Example: http://+:5000;https://+:5001
# Where to obtain: Default ports for development
ASPNETCORE_URLS=http://+:5000;https://+:5001

# ----------------------------------------------------------------------------
# VIDEO PROCESSING
# ----------------------------------------------------------------------------

# Maximum Video File Size
# Required: NO
# Description: Maximum allowed video upload size in MB
# Example: 500
# Where to obtain: Adjust based on your needs
Video__MaxFileSizeMB=500

# ----------------------------------------------------------------------------
# HEALTH CHECKS
# ----------------------------------------------------------------------------

# Health Check Interval
# Required: NO
# Description: Interval in seconds for health check evaluations
# Example: 30
# Where to obtain: Default value
HEALTH_CHECK_INTERVAL_SECONDS=30

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. NEVER commit the actual .env file to source control
# 2. For local development, you can use relaxed security settings
# 3. Use Docker Compose to run SQL Server locally
# 4. Consider using Azure Storage Emulator (Azurite) for local development
# 5. Most monitoring and email features can be disabled in development
# 
# To create your .env file:
# 1. Copy this file: cp .env.development.example .env
# 2. Update values with your local configuration
# 3. Ensure .env is in .gitignore
# 
# ============================================================================
