# ===========================================
# Podium Application Environment Variables
# ===========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control

# -----------------------------------------
# Database Configuration
# -----------------------------------------
# SQL Server SA Password (REQUIRED for Docker deployment)
# Must be at least 8 characters with uppercase, lowercase, numbers and symbols
DB_SA_PASSWORD=YourVeryStrongPassword123!

# Database Connection String
# For Docker: Use service name 'db' and reference DB_SA_PASSWORD
ConnectionStrings__DefaultConnection=Server=db;Database=PodiumDb;User Id=sa;Password=YourVeryStrongPassword123!;TrustServerCertificate=true;MultipleActiveResultSets=true
# For local development with Windows Authentication:
# ConnectionStrings__DefaultConnection=Server=(localdb)\\mssqllocaldb;Database=PodiumDb;Trusted_Connection=true;MultipleActiveResultSets=true

# -----------------------------------------
# JWT Authentication
# -----------------------------------------
JWT__Secret=YourSuperSecretKeyThatIsAtLeast32CharactersLong!ChangeThisInProduction
JWT__Issuer=PodiumAPI
JWT__Audience=PodiumClient
JWT__ExpirationMinutes=60

# -----------------------------------------
# Video Processing
# -----------------------------------------
Video__TranscodingSecret=YourSecureRandomStringHere123!ChangeThisInProduction
Video__MaxFileSizeMB=500

# -----------------------------------------
# Storage Configuration
# -----------------------------------------
# Options: Azure, AWS
StorageProvider=Azure

# Azure Storage Settings
AzureStorage__ConnectionString=DefaultEndpointsProtocol=https;AccountName=youraccountname;AccountKey=youraccountkey;EndpointSuffix=core.windows.net
AzureStorage__ContainerName=podium-videos

# AWS Storage Settings (if using AWS)
AWS__Region=us-east-1
AWS__BucketName=podium-videos-bucket
AWS__AccessKey=YOUR_AWS_ACCESS_KEY
AWS__SecretKey=YOUR_AWS_SECRET_KEY

# -----------------------------------------
# Email Service (SendGrid)
# -----------------------------------------
SendGrid__ApiKey=YOUR_SENDGRID_API_KEY
SendGrid__FromEmail=noreply@podiumapp.com
SendGrid__FromName=Podium Application

# -----------------------------------------
# CORS Configuration
# -----------------------------------------
AllowedOrigins__0=http://localhost:4200
AllowedOrigins__1=https://yourdomain.com

# -----------------------------------------
# Application Settings
# -----------------------------------------
App__ClientUrl=http://localhost:4200

# -----------------------------------------
# Rate Limiting
# -----------------------------------------
RateLimit__EnableRateLimiting=true
RateLimit__PermitLimit=10
RateLimit__WindowSeconds=60

# -----------------------------------------
# Logging
# -----------------------------------------
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft=Warning
Logging__LogLevel__MicrosoftAspNetCore=Warning

# Serilog Configuration
Serilog__MinimumLevel__Default=Information
Serilog__MinimumLevel__Override__Microsoft=Warning
Serilog__MinimumLevel__Override__System=Warning
Serilog__WriteTo__0__Name=Console
Serilog__WriteTo__1__Name=File
Serilog__WriteTo__1__Args__path=logs/podium-.log
Serilog__WriteTo__1__Args__rollingInterval=Day
Serilog__WriteTo__1__Args__retainedFileCountLimit=7

# -----------------------------------------
# Environment
# -----------------------------------------
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000

# -----------------------------------------
# Security Headers
# -----------------------------------------
SecurityHeaders__EnableHSTS=true
SecurityHeaders__HSTSMaxAge=31536000
SecurityHeaders__EnableCSP=true
# ============================================
# Podium Docker Environment Variables
# ============================================
# Copy this file to .env and update with your values
# IMPORTANT: Never commit .env to version control

# ============================================
# Database Configuration
# ============================================
# SQL Server SA password (minimum 8 characters, requires complexity)
SQL_SA_PASSWORD=YourStrong!Passw0rd

# Production database connection string (for docker-compose.prod.yml)
DATABASE_CONNECTION_STRING=Server=your-server.database.windows.net;Database=PodiumDb;User Id=your-user;Password=your-password;TrustServerCertificate=True;MultipleActiveResultSets=true

# ============================================
# JWT Authentication
# ============================================
# Secret key for JWT token signing (minimum 32 characters)
JWT_SECRET=YourSuperSecretKeyThatIsAtLeast32CharactersLong!
JWT_ISSUER=PodiumAPI
JWT_AUDIENCE=PodiumClient
JWT_EXPIRATION_MINUTES=60

# ============================================
# Azure Storage Configuration
# ============================================
# Production Azure Storage connection string
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net
AZURE_CONTAINER_NAME=podium-videos

# ============================================
# AWS Configuration (if using AWS S3)
# ============================================
AWS_REGION=us-east-1
AWS_BUCKET_NAME=podium-videos-bucket
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key

# ============================================
# Video Processing
# ============================================
VIDEO_TRANSCODING_SECRET=YourSecureRandomStringHere123!
VIDEO_MAX_FILE_SIZE_MB=500

# ============================================
# Frontend/Backend URLs
# ============================================
# Backend API URL (used by frontend)
API_URL=http://localhost:5044

# Frontend URL (used by backend for CORS and callbacks)
CLIENT_URL=http://localhost:4200
FRONTEND_URL_0=https://your-production-domain.com
FRONTEND_URL_1=https://www.your-production-domain.com

# ============================================
# Port Configuration
# ============================================
BACKEND_PORT=5044
FRONTEND_PORT=4200

# ============================================
# Email Configuration (SendGrid)
# ============================================
SENDGRID_API_KEY=your-sendgrid-api-key

# ============================================
# Application Settings
# ============================================
# Development or Production
ASPNETCORE_ENVIRONMENT=Development
